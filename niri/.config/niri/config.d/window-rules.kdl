workspace "¾░ł╣"
workspace "ŅŻÜ"
workspace "ŅłŚ"
workspace "¾░”æ"
workspace "¾░ŖŚ"


/* ----- Browser -----*/
window-rule {
    match app-id="zen"

    open-on-workspace "¾░ł╣"
    open-maximized true
}

window-rule {
    // This app-id regular expression will work for both:
    // - host Firefox (app-id is "firefox")
    // - Flatpak Firefox (app-id is "org.mozilla.firefox")
    match app-id=r#"zen$"# title="^Picture-in-Picture$"
    open-floating true
}


/* ----- Code -----*/
window-rule {
    match app-id="code-oss"

    open-on-workspace "ŅŻÜ"
    open-maximized-to-edges true
}


/* ----- Rostelecom -----*/
window-rule {
    match app-id="org.remmina.Remmina"
    match app-id="TrueConf"
    match app-id="snx-rs-gui"

    open-on-workspace "¾░”æ"
}
window-rule {
    match app-id="org.remmina.Remmina" title="RTK"

    open-fullscreen true
}

/*----- Chat -----*/
window-rule {
    match app-id="org.telegram.desktop"

    open-on-workspace "ŅłŚ"
    open-maximized true
}


/*----- Games -----*/
window-rule {
    match app-id="(steam_app_default|steam|net.lutris.Lutris)"

    open-on-workspace "¾░ŖŚ"
}