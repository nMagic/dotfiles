workspace "¾░ê╣"
workspace "¯úÜ"
workspace "¯êù"
workspace "¾░ªæ"
workspace "¾░èù"


/* ----- Browser -----*/
window-rule {
    match app-id="zen"

    open-on-workspace "¾░ê╣"
    open-maximized true
}

window-rule {
    // This app-id regular expression will work for both:
    // - host Firefox (app-id is "firefox")
    // - Flatpak Firefox (app-id is "org.mozilla.firefox")
    match app-id=r#"zen$"# title="^Picture-in-Picture$"
    open-floating true
}


/* ----- Code -----*/
window-rule {
    match app-id="code-oss"

    open-on-workspace "¯úÜ"
    open-maximized true
}


/* ----- Rostelecom -----*/
window-rule {
    match app-id="org.remmina.Remmina"
    match app-id="TrueConf"
    match app-id="snx-rs-gui"
    match app-id="vivaldi-stable"
    match app-id="YuChat"

    open-on-workspace "¾░ªæ"
}

window-rule {
    match title="VPN Authentication Factor"
    match app-id="snx-rs-gui"

    open-floating true
    open-focused true

    default-column-width { fixed 680; }
    default-window-height { fixed 150; }
}

window-rule {
    match app-id="org.remmina.Remmina" title="RTK"

    open-fullscreen true
}

window-rule {
    match app-id="vivaldi-stable"

    open-maximized true
}

/*----- Chat -----*/
window-rule {
    match app-id="(org.telegram.desktop|discord)"

    open-on-workspace "¯êù"
    open-maximized true
}


/*----- Games -----*/
window-rule {
    match app-id="(steam_app_default|steam|net.lutris.Lutris)"

    open-on-workspace "¾░èù"
}


/*----- Screensaver -----*/
window-rule {
    match app-id="Screensaver"

    open-fullscreen true
}
